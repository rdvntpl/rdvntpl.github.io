---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import CallToAction from '../../components/CallToAction.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PostPreview from '../../components/PostPreview.astro';
import Subscribe from '../../components/Subscribe.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';
import { slugify } from '../../utils/common-utils';

export async function getStaticPaths() {
    const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
    const postCount = posts.length;
    return posts.map((post, index) => ({
        params: { id: post.id },
        props: {
            post,
            prevPost: index + 1 !== postCount ? posts[index + 1] : null,
            nextPost: index !== 0 ? posts[index - 1] : null,
            relatedPosts: posts
                .filter((candidate) => candidate.id !== post.id)
                .filter((candidate) => candidate.data.tags.some((tag) => post.data.tags.includes(tag)))
                .slice(0, 2)
        }
    }));
}

type Props = {
    post: CollectionEntry<'blog'>;
    prevPost: CollectionEntry<'blog'> | null;
    nextPost: CollectionEntry<'blog'> | null;
    relatedPosts: CollectionEntry<'blog'>[];
};

const { href } = Astro.url;
const { post, prevPost, nextPost, relatedPosts } = Astro.props;
const { title, publishDate, updatedDate, excerpt, summary, tags = [], technologies = [], cta, seo } = post.data;
const { Content } = await render(post);
const description = seo?.description ?? summary ?? excerpt;
const structuredData = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: seo?.title ?? title,
    description,
    image: seo?.image?.src ? new URL(seo.image.src, Astro.site).toString() : undefined,
    datePublished: publishDate.toISOString(),
    dateModified: (updatedDate || publishDate).toISOString(),
    author: {
        '@type': 'Person',
        name: 'Rıdvan Topal'
    },
    mainEntityOfPage: Astro.url.href,
    keywords: tags
};
---

<BaseLayout
    title={seo?.title ?? title}
    description={description}
    image={seo?.image}
    pageType={seo?.pageType ?? 'article'}
    keywords={seo?.keywords ?? tags}
    publishedTime={publishDate.toISOString()}
    modifiedTime={(updatedDate || publishDate).toISOString()}
    structuredData={seo?.structuredData ?? structuredData}
    showHeader={false}
>
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="text-3xl leading-tight font-serif font-medium sm:text-5xl sm:leading-tight">{title}</h1>
            <div class="mt-4 text-sm">
                <FormattedDate date={publishDate} />
                {
                    updatedDate && (
                        <>
                            {' '}
                            <span>
                                (Updated on <FormattedDate date={updatedDate} />)
                            </span>
                        </>
                    )
                }
            </div>
            {(summary || excerpt) && <p class="mt-4 max-w-2xl text-sm leading-relaxed sm:text-base">{summary || excerpt}</p>}
            {(tags.length > 0 || technologies.length > 0) && (
                <div class="mt-5 flex flex-wrap gap-2">
                    {tags.map((tag) => (
                        <a class="rounded-full border border-dashed border-main px-2.5 py-1 text-xs hover:bg-muted" href={`/tags/${slugify(tag)}`}>
                            #{tag}
                        </a>
                    ))}
                    {technologies.map((technology) => (
                        <span class="rounded-full border border-dashed border-main px-2.5 py-1 text-xs">{technology}</span>
                    ))}
                </div>
            )}
        </header>
        <div class="max-w-none prose prose-dante sm:prose-lg">
            <Content />
        </div>
        <div class="mt-8 flex flex-wrap items-center gap-6 text-sm justify-between sm:mt-12 sm:text-base">
            <Button class="copy-url-button" aria-label="Copy link" data-url={href} data-tooltip-default="Copy link" data-tooltip-success="Copied">Share</Button>
        </div>
    </article>
    <CallToAction cta={cta} class="mb-16 sm:mb-24" />
    {
        relatedPosts.length > 0 && (
            <div class="my-16 sm:my-24">
                <h2 class="mb-12 text-xl font-serif italic sm:mb-16 sm:text-2xl">Related Posts</h2>
                {relatedPosts.map((relatedPost) => (
                    <PostPreview post={relatedPost} class="mb-10 sm:mb-12" headingLevel="h3" />
                ))}
            </div>
        )
    }
    {
        (prevPost || nextPost) && (
            <div class="my-16 sm:my-24">
                <h2 class="mb-12 text-xl font-serif italic sm:mb-16 sm:text-2xl">Read Next</h2>
                {nextPost && <PostPreview post={nextPost} class="mb-10 sm:mb-12" headingLevel="h3" />}
                {prevPost && <PostPreview post={prevPost} class="mb-10 sm:mb-12" headingLevel="h3" />}
            </div>
        )
    }
    <Subscribe class="my-16 sm:my-24" />
</BaseLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const copyUrlButton = document.querySelector('.copy-url-button') as HTMLButtonElement;
        copyUrlButton?.addEventListener('click', async () => {
            await copyUrl(copyUrlButton);
        });

        async function copyUrl(button: HTMLButtonElement) {
            let url = button.getAttribute('data-url') || '';
            let label = button.innerText;

            await navigator.clipboard.writeText(url);

            button.innerText = 'Copied';

            setTimeout(() => {
                button.innerText = label;
            }, 2500);
        }
    });
</script>
