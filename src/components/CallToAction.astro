---
import Button from './Button.astro';

type Action = {
    label: string;
    href: string;
    external?: boolean;
    type?: 'primary' | 'secondary';
};

type CTA = {
    title?: string;
    text?: string;
    action?: Action;
};

type Props = {
    cta?: CTA;
    class?: string;
};

const { cta, class: className } = Astro.props;
---

{
    cta && (cta.title || cta.text || cta.action) && (
        <section class:list={['border border-dashed border-main px-6 py-8 sm:px-8 sm:py-10', className]}>
            {cta.title && <h2 class="text-2xl leading-tight font-serif font-medium sm:text-3xl">{cta.title}</h2>}
            {cta.text && <p class:list={['max-w-2xl text-sm leading-relaxed sm:text-base', cta.title ? 'mt-3' : '']}>{cta.text}</p>}
            {cta.action && (
                <div class="mt-6">
                    <Button href={cta.action.href} target={cta.action.external ? '_blank' : undefined} rel={cta.action.external ? 'noreferrer noopener' : undefined}>
                        {cta.action.label}
                    </Button>
                </div>
            )}
        </section>
    )
}
